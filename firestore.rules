rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Submissions — anyone can create (quiz submits from browser)
    match /submissions/{submissionId} {
      allow create: if true;
      allow read: if true;
      allow update: if false;
      allow delete: if false;
    }

    // Brand kits — read-only (written by server Admin SDK which bypasses rules)
    match /brandKits/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // Generation jobs — server-only (Admin SDK bypasses rules)
    match /generationJobs/{jobId} {
      allow read, write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
